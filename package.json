{
  "name": "steam-sales-dashboard",
  "private": true,
  "version": "1.0.0",
  "description": "A modern dashboard for Steam Sales",
  "author": "Trae",
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.steamsales.dashboard",
    "productName": "Steam Sales Dashboard",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "mac": {
      "icon": "build/icon.icns",
      "identity": null,
      "target": ["dmg", "zip"],
      "extendInfo": {
        "CFBundleIconFile": "icon.icns"
      }
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": ["AppImage"]
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "csv-parse": "^6.1.0",
    "date-fns": "^4.1.0",
    "electron-is-dev": "^3.0.1",
    "framer-motion": "^12.35.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-countup": "^6.5.3",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^9.0.4"
  }
}
